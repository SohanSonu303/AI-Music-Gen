# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>          # backend / Celery — bypasses RLS
SUPABASE_ANON_KEY=<anon-key>             # per-request RLS-scoped clients
SUPABASE_JWT_SECRET=<jwt-secret>         # Clerk JWT Template signing key

# Storage buckets
BUCKET_NAME=music-generated
SFX_BUCKET_NAME=sfx

# MusicGPT
MUSICGPT_API_KEY=<musicgpt-api-key>
MUSICGPT_MAX_PARALLEL=1

# OpenRouter (LangGraph agents)
OPENROUTER_API_KEY=<openrouter-api-key>

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Clerk auth
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_WEBHOOK_SECRET=whsec_<svix-webhook-secret>

DEV_BYPASS_AUTH=false

IS_MOCK=false

# Docker image to use. Set this on the server when pulling a pre-built image.
# Leave unset when building locally with: docker compose up --build
# DOCKER_IMAGE=yourdockerhubusername/aimusic-app:latest